# =============================================================================
# Code Interpreter (codeapi) example environment
# Copy to .env and adjust. Values shown are safe local-development defaults.
# The default docker-compose files already inline most of these; override here
# only what your deployment needs. See README.md "LibreChat integration".
# =============================================================================

# -----------------------------------------------------------------------------
# Core / mode
# -----------------------------------------------------------------------------
# LOCAL_MODE=true bypasses authentication entirely (local/dev only).
# Set to false for any authenticated (JWT) deployment.
LOCAL_MODE=true
# Keep the microVM + NsJail hardening on. Only disable for local debugging.
CODEAPI_HARDENED_SANDBOX_MODE=true

# -----------------------------------------------------------------------------
# LibreChat authentication (API component)
# -----------------------------------------------------------------------------
# Auth mode: "librechat-jwt" (default) or "none". Unset defaults to librechat-jwt.
CODEAPI_AUTH_PROVIDER=
# Allow CODEAPI_AUTH_PROVIDER=none outside LOCAL_MODE (must be "true" to take effect).
CODEAPI_ALLOW_AUTH_PROVIDER_NONE=
# JWT verifier settings. Issuer/audience/kid/alg must match what LibreChat signs.
CODEAPI_JWT_ISSUER=librechat
CODEAPI_JWT_AUDIENCE=codeapi
CODEAPI_JWT_ALLOWED_ALGS=EdDSA
CODEAPI_JWT_KID=lc-codeapi-1
# Verifier public key (PEM or base64 DER; escaped \n allowed). One of:
#   CODEAPI_JWT_PUBLIC_KEY (+ CODEAPI_JWT_KID), CODEAPI_JWT_JWKS_JSON, or
#   CODEAPI_JWT_PUBLIC_KEYS_DIR (directory of PEM files named by kid).
CODEAPI_JWT_PUBLIC_KEY=
CODEAPI_JWT_JWKS_JSON=
CODEAPI_JWT_PUBLIC_KEYS_DIR=
# Token lifetime cap (seconds, max 300) and clock skew tolerance (seconds, max 30).
CODEAPI_JWT_MAX_TTL_SECONDS=300
CODEAPI_JWT_CLOCK_SKEW_SECONDS=30

# -----------------------------------------------------------------------------
# Internal service auth / secrets
# -----------------------------------------------------------------------------
# Shared token between components (file object + tool-call session routes).
# MUST be a strong secret in production; unset leaves those routes open.
CODEAPI_INTERNAL_SERVICE_TOKEN=
# Signs egress grants issued to sandboxes (32+ bytes in production).
CODEAPI_EGRESS_GRANT_SECRET=
# Signed execution manifests: worker signs with the private key, sandbox-runner
# verifies with the public key. Ed25519, base64 DER or PEM.
CODEAPI_EXECUTION_MANIFEST_PRIVATE_KEY=
SANDBOX_EXECUTION_MANIFEST_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Redis (job queue + session/key cache)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=localdev

# -----------------------------------------------------------------------------
# MinIO / S3 (File Server)
# -----------------------------------------------------------------------------
FILE_SERVER_PORT=3000
MINIO_BUCKET=test-bucket
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Set true for gateways that must not receive an explicit port (ignores MINIO_PORT).
MINIO_NO_PORT=false

# -----------------------------------------------------------------------------
# Sandbox runner
# -----------------------------------------------------------------------------
# KVM_ENABLED=true runs the libkrun microVM (needs /dev/kvm). Set false for
# NsJail-only mode (weaker isolation; see README "Running without KVM").
KVM_ENABLED=true
KVM_DEVICE_PATH=/dev/kvm
SANDBOX_USE_CGROUPV2=true
SANDBOX_LOG_LEVEL=DEBUG
SANDBOX_MAX_PROCESS_COUNT=100
SANDBOX_MAX_CONCURRENT_JOBS=8
SANDBOX_RUN_CPU_TIME=300000
SANDBOX_RUN_TIMEOUT=300000
SANDBOX_OUTPUT_MAX_SIZE=65536

# microVM launcher resources (per sandbox).
LAUNCHER_VCPUS=2
LAUNCHER_RAM_MIB=2048
LAUNCHER_LOG_LEVEL=3

# -----------------------------------------------------------------------------
# Worker concurrency
# -----------------------------------------------------------------------------
PYTHON_CONCURRENCY=1
OTHER_CONCURRENCY=8
JOB_WINDOW=1000

# -----------------------------------------------------------------------------
# Language runtimes (package_init)
# -----------------------------------------------------------------------------
# Comma-separated subset of python,node,bun,bash,java (default: all). See README.
CODEAPI_LANGUAGES=
# Host path where downloaded runtimes are cached (mounted into sandboxes).
SANDBOX_PACKAGES_PATH=./data/pkgs

# -----------------------------------------------------------------------------
# Persistent sessions (opt-in, OFF by default)
# -----------------------------------------------------------------------------
# When true, each run's /mnt/data workspace (files + a dill-serialized Python
# global namespace) is snapshotted to object storage under the caller's own
# sessionKey and restored on their next run, so variables and files carry across
# calls with NO client change. Keyed on the auth-derived, manifest-bound
# sessionKey (per authenticated user/resource, not per conversation). See
# README "Persistent sessions".
CODEAPI_PERSIST_SESSIONS=false
# Max size of the snapshot tar; larger workspaces skip the snapshot (the run
# still succeeds) rather than balloon storage. Default 100 MiB. This is the
# ONLY knob bounding snapshot size: in hardened mode the gateway/ledger exempt
# the hidden snapshot from EGRESS_GATEWAY_MAX_FILE_BYTES (which sizes user
# output files) and enforce this cap instead.
CODEAPI_SESSION_STATE_MAX_BYTES=104857600
# Idle expiry for a session's Redis POINTER, refreshed on every run -- an
# active session's pointer never lapses. NOTE: this expires only the pointer;
# the snapshot tar object in storage is NOT deleted by this TTL (it is only
# deleted when a later run of the same session supersedes it). To reclaim
# storage from abandoned sessions, configure a lifecycle policy on the
# underlying bucket/prefix -- see "Persistent sessions" in the README.
# Default 7d.
CODEAPI_SESSION_STATE_TTL_SECONDS=604800

# Runtime downloads are verified against SHA-256 checksums pinned for the
# default versions. When you override a runtime version, package_init verifies
# against the provider's published checksum file; set the matching hash below
# to pin a custom version instead (leave blank to use the pinned/fetched value).
PYTHON_SHA256=
NODE_SHA256=
BUN_SHA256=
JAVA_SHA256=

# -----------------------------------------------------------------------------
# Dynamic per-job dependency install (opt-in, OFF by default)
# -----------------------------------------------------------------------------
# When true, an exec request may declare pinned pip packages that the runner
# installs (wheels only -> no build/setup.py code runs) into a per-job dir
# mounted read-only into the sandbox. The sandbox itself gains no network; the
# runner needs outbound HTTPS to the index below. See README "Dynamic
# dependencies". Leave false unless you understand the trade-off.
CODEAPI_ALLOW_DYNAMIC_DEPENDENCIES=false
CODEAPI_DEPENDENCY_INDEX_URL=https://pypi.org/simple
CODEAPI_DEPENDENCY_MAX_COUNT=50
CODEAPI_DEPENDENCY_INSTALL_TIMEOUT_MS=120000
CODEAPI_DEPENDENCY_MAX_BYTES=262144000
